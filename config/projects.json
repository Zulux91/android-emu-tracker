{
  "_instructions": {
    "description": "This is the single source of truth for all tracked projects. Edit the 'projects' array below to add or remove entries, then run: npm run fetch && npm run build",
    "required_fields": {
      "name": "Display name shown in the ranking dashboard.",
      "repo": "GitHub: 'owner/repo'. Gitea: 'owner/repo' (also set apiType and apiHost). Special case — 'skipFetch: true' lets you list a project without making any API call.",
      "category": "Controls which tab the project appears under. 'Drivers' goes to the Drivers Library tab; everything else appears in the main Ranking tab. Any string is valid — inventing a new category automatically adds it as a filter option."
    },
    "optional_fields": {
      "logo": "Image filename inside public/logos/. Drop the file there and reference it here. Example: \"gamehub.png\"",
      "extensions": "Extra file extensions counted as valid downloadable assets, in addition to the default .apk. Example: [\".zip\"] for GPU drivers, [\".wcp\"] for wine containers, [\".tar.gz\"] for tarballs. Only assets matching these extensions appear in the release modal and recent-releases tab.",
      "apiType": "Set to \"gitea\" for Gitea-hosted repos or \"forgejo\" for Forgejo-hosted repos (e.g. git.eden-emu.dev, Codeberg). Omit entirely for GitHub. Both use the same /api/v1/ endpoint today but are tracked separately for forward compatibility.",
      "apiHost": "Required when apiType is \"gitea\" or \"forgejo\". Full base URL of the instance. Example: \"https://git.citron-emu.org\", \"https://git.eden-emu.dev\"",
      "upstream": "Optional grouping key for related forks. Example: \"winlator\" links all Winlator forks together. Not yet exposed in the UI but available for future use.",
      "skipFetch": "Set to true to include a project in the listing without calling any API. Downloads will show as 0 and only a repository link is shown. Useful for repos that are link-only or frequently rate-limited."
    },
